# Server
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://shippublic:shippublic@localhost:5432/shippublic?schema=public

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production-please-32chars-min
JWT_EXPIRES_IN=7d
COOKIE_NAME=shippublic_session

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=replace-with-strong-random-string

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CODER_MODEL=qwen2.5-coder:32b
OLLAMA_CHAT_MODEL=qwen3:32b
